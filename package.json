{
  "name": "pindou-studio",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.0.0 <25"
  },
  "overrides": {
    "brace-expansion@^1.0.0": "1.1.16",
    "brace-expansion@^2.0.0": "2.1.2",
    "postcss": "8.5.19",
    "serialize-javascript": "7.0.7"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:edge": "playwright test --project=msedge --workers=1",
    "fixtures:generate": "node scripts/generate-phase1-fixtures.mjs",
    "fixtures:check": "node scripts/generate-phase1-fixtures.mjs --check",
    "licenses:generate": "node scripts/generate-third-party-licenses.mjs",
    "licenses:check": "node scripts/generate-third-party-licenses.mjs --check",
    "security:check": "node scripts/check-known-vulnerabilities.mjs",
    "audit:prod:online": "npm audit --omit=dev --audit-level=high",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run fixtures:check && npm run licenses:check && npm run security:check && npm run audit:prod:online && npm run build"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "10.2.9",
    "next": "15.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "sharp": "^0.34.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "4.1.10"
  }
}
