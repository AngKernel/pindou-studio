# 公开稳定版默认只运行浏览器本地功能，不连接 bead-cloud。
NEXT_PUBLIC_DEPLOYMENT_MODE=local-only

# 公开部署时必须指向该部署版本对应的 pindou-studio 源码仓库。
NEXT_PUBLIC_SOURCE_CODE_URL=https://github.com/AngKernel/pindou-studio

# 仅在 NEXT_PUBLIC_DEPLOYMENT_MODE=cloud 时配置，且必须是 HTTPS origin。
# NEXT_PUBLIC_BEAD_CLOUD_API_URL=https://license.example
